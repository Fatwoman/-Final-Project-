## 7 segment display (段選: 7個燈)
set_property PACKAGE_PIN W7 [get_ports {seg[0]}]					
	set_property IOSTANDARD LVCMOS33 [get_ports {seg[0]}]
set_property PACKAGE_PIN W6 [get_ports {seg[1]}]					
	set_property IOSTANDARD LVCMOS33 [get_ports {seg[1]}]
set_property PACKAGE_PIN U8 [get_ports {seg[2]}]					
	set_property IOSTANDARD LVCMOS33 [get_ports {seg[2]}]
set_property PACKAGE_PIN V8 [get_ports {seg[3]}]					
	set_property IOSTANDARD LVCMOS33 [get_ports {seg[3]}]
set_property PACKAGE_PIN U5 [get_ports {seg[4]}]					
	set_property IOSTANDARD LVCMOS33 [get_ports {seg[4]}]
set_property PACKAGE_PIN V5 [get_ports {seg[5]}]					
	set_property IOSTANDARD LVCMOS33 [get_ports {seg[5]}]
set_property PACKAGE_PIN U7 [get_ports {seg[6]}]					
	set_property IOSTANDARD LVCMOS33 [get_ports {seg[6]}]

## Anodes (選位: 4個位置)
set_property PACKAGE_PIN U2 [get_ports {an[0]}]					
	set_property IOSTANDARD LVCMOS33 [get_ports {an[0]}]
set_property PACKAGE_PIN U4 [get_ports {an[1]}]					
	set_property IOSTANDARD LVCMOS33 [get_ports {an[1]}]
set_property PACKAGE_PIN V4 [get_ports {an[2]}]					
	set_property IOSTANDARD LVCMOS33 [get_ports {an[2]}]
set_property PACKAGE_PIN W4 [get_ports {an[3]}]					
	set_property IOSTANDARD LVCMOS33 [get_ports {an[3]}]
	
## [新增] 按鈕 (右邊按鈕 T17) -> 查詢分數功能
set_property PACKAGE_PIN T17 [get_ports btn_score]                        
	set_property IOSTANDARD LVCMOS33 [get_ports btn_score]
	
## [新增] 遊戲啟動/停止按鈕 (下方的按鈕 U17/btnD)
set_property PACKAGE_PIN U17 [get_ports btn_u17]                        
    set_property IOSTANDARD LVCMOS33 [get_ports btn_u17]

## [新增] UART 傳輸線 (連接到電腦)
set_property PACKAGE_PIN A18 [get_ports RsTx]                        
    set_property IOSTANDARD LVCMOS33 [get_ports RsTx]
    
    
## Buttons
# ... 原本的 btn_score (T17), btn_u17 (U17), reset 等等 ...

# [新增] 綁定左邊按鈕 btnL (腳位 W19) 給 btn_l
set_property PACKAGE_PIN W19 [get_ports btn_l]
set_property IOSTANDARD LVCMOS33 [get_ports btn_l]